        "destination": "http://localhost:8080/api/v1/:path*",
        "regex": "^/api/v1(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/jobs/[jobId]",
      "regex": "^/jobs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPjobId": "nxtPjobId"
      },
      "namedRegex": "^/jobs/(?<nxtPjobId>[^/]+?)(?:/)?$"
    }
  ],
