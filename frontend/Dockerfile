FROM node:22-alpine
WORKDIR /app
COPY package.json ./
RUN npm install
COPY . .
ARG BACKEND_API_BASE_URL=http://localhost:8080
ENV BACKEND_API_BASE_URL=$BACKEND_API_BASE_URL
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID=
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=$NEXT_PUBLIC_GOOGLE_CLIENT_ID
RUN npm run build
EXPOSE 3000
CMD ["npm", "run", "start"]
